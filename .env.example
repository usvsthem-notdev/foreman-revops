# Foreman RevOps Tracker — environment configuration
# Copy to .env and edit. Never commit .env to version control.

# Path for the local SQLite database.
# Defaults to ./data/foreman.db if not set.
# Must be within your home directory or /tmp.
# FOREMAN_DB_PATH=/path/to/your/foreman.db

# Streamlit server settings (optional overrides).
# See: https://docs.streamlit.io/develop/api-reference/configuration
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=localhost
